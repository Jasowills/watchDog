PORT=8080
NODE_ENV=development

# MongoDB connection string used by Prisma.
# Local: mongodb://localhost:27017/watchdog
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/watchdog
DATABASE_URL=

# JWT secret used to sign and verify authentication tokens.
# Generate one: openssl rand -base64 32
JWT_SECRET=

# Google OAuth credentials (from Google Cloud Console → Credentials → OAuth 2.0 Client ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
