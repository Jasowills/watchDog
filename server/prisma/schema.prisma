generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MonitorType {
  HTTP
}

enum MonitorState {
  HEALTHY
  DEGRADED
  DOWN
}

enum DeploymentStatus {
  IN_PROGRESS
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

enum IncidentSeverity {
  SEV_1
  SEV_2
  SEV_3
  SEV_4
}

enum IncidentStatus {
  DETECTED
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum IncidentUpdateKind {
  DETECTED
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
  NOTE
}

enum ErrorGroupStatus {
  OPEN
  IGNORED
  RESOLVED
}

enum AlertChannelType {
  EMAIL
  SLACK
  WEBHOOK
}

enum AlertTriggerType {
  MONITOR_DOWN
  INCIDENT_CREATED
  ERROR_SPIKE
}

enum StatusPageVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id              String           @id @default(cuid())
  authUserId      String           @unique
  email           String           @unique
  fullName        String?
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  ownedIncidents  Incident[]       @relation("IncidentOwner")
  incidentUpdates IncidentUpdate[]
  alertChannels   AlertChannel[]
}

model Workspace {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  projects      Project[]
  incidents     Incident[]
  alertChannels AlertChannel[]
  alertRules    AlertRule[]
  statusPages   StatusPage[]
}

model Membership {
  id          String         @id @default(cuid())
  role        MembershipRole
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspaceId String
  userId      String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Project {
  id            String        @id @default(cuid())
  name          String
  slug          String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  environments  Environment[]
  services      Service[]
  incidents     Incident[]
  errorGroups   ErrorGroup[]
  alertRules    AlertRule[]
  statusPages   StatusPage[]

  @@unique([workspaceId, slug])
}

model Environment {
  id           String       @id @default(cuid())
  name         String
  key          String
  color        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  monitors     Monitor[]
  incidents    Incident[]
  errorGroups  ErrorGroup[]
  alertRules   AlertRule[]
  deployments  Deployment[]

  @@unique([projectId, key])
}

model Service {
  id               String             @id @default(cuid())
  name             String
  slug             String
  description      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  projectId        String
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  monitors         Monitor[]
  incidents        Incident[]
  errorGroups      ErrorGroup[]
  statusPageLinks  StatusPageService[]
  alertRules       AlertRule[]
  deployments      Deployment[]

  @@unique([projectId, slug])
}

model Monitor {
  id              String         @id @default(cuid())
  name            String
  type            MonitorType    @default(HTTP)
  targetUrl       String
  method          String         @default("GET")
  expectedStatus  Int            @default(200)
  expectedKeyword String?
  intervalSeconds Int            @default(30)
  timeoutSeconds  Int            @default(10)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  serviceId       String
  environmentId   String
  service         Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  environment     Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  checkResults    CheckResult[]
}

model CheckResult {
  id           String       @id @default(cuid())
  state        MonitorState
  statusCode   Int?
  latencyMs    Int?
  region       String?
  errorMessage String?
  metadata     Json?
  checkedAt    DateTime     @default(now())
  monitorId    String
  monitor      Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

model Incident {
  id                String            @id @default(cuid())
  title             String
  summary           String?
  severity          IncidentSeverity
  status            IncidentStatus
  startedAt         DateTime
  resolvedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspaceId       String
  projectId         String
  environmentId     String?
  serviceId         String?
  ownerUserId       String?
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment       Environment?      @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  service           Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  owner             User?             @relation("IncidentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  updates           IncidentUpdate[]
}

model IncidentUpdate {
  id          String             @id @default(cuid())
  kind        IncidentUpdateKind
  body        String
  createdAt   DateTime           @default(now())
  incidentId  String
  actorUserId String?
  incident    Incident           @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actor       User?              @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model ErrorGroup {
  id              String           @id @default(cuid())
  fingerprint     String
  title           String
  status          ErrorGroupStatus @default(OPEN)
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  occurrenceCount Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  projectId       String
  environmentId   String
  serviceId       String?
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     Environment      @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  service         Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  events          ErrorEvent[]

  @@unique([environmentId, fingerprint])
}

model ErrorEvent {
  id           String     @id @default(cuid())
  eventKey     String     @unique
  message      String
  stack        String?
  release      String?
  metadata     Json?
  occurredAt   DateTime
  createdAt    DateTime   @default(now())
  errorGroupId String
  errorGroup   ErrorGroup @relation(fields: [errorGroupId], references: [id], onDelete: Cascade)
}

model AlertChannel {
  id             String           @id @default(cuid())
  name           String
  type           AlertChannelType
  destination    String
  secretRef      String?
  isEnabled      Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspaceId    String
  creatorUserId  String?
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator        User?            @relation(fields: [creatorUserId], references: [id], onDelete: SetNull)
  alertRules     AlertRule[]
}

model AlertRule {
  id                String            @id @default(cuid())
  name              String
  triggerType       AlertTriggerType
  minimumSeverity   IncidentSeverity?
  isEnabled         Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspaceId       String
  projectId         String?
  environmentId     String?
  serviceId         String?
  alertChannelId    String
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project           Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment       Environment?      @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  service           Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  alertChannel      AlertChannel      @relation(fields: [alertChannelId], references: [id], onDelete: Cascade)
}

model StatusPage {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  headline      String?
  visibility    StatusPageVisibility @default(PUBLIC)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspaceId   String
  projectId     String?
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  services      StatusPageService[]
}

model StatusPageService {
  id            String      @id @default(cuid())
  displayName   String?
  sortOrder     Int         @default(0)
  statusPageId  String
  serviceId     String
  statusPage    StatusPage  @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([statusPageId, serviceId])
}

model Deployment {
  id            String           @id @default(cuid())
  version       String
  status        DeploymentStatus @default(SUCCEEDED)
  description   String?
  deployedBy    String?
  deployedAt    DateTime         @default(now())
  createdAt     DateTime         @default(now())
  environmentId String
  serviceId     String?
  environment   Environment      @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  service       Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([environmentId, deployedAt])
}