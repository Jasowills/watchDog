generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ── Enums are not supported by the MongoDB provider.
//     All enum-like fields are String. Validate values in application code.
// ── Composite @@unique constraints are not supported by the MongoDB provider.
//     Scoped uniqueness (e.g. slug unique within a workspace) is enforced
//     via application-level findFirst checks before create.
// ── @default(now()) and @updatedAt are not supported.
//     Timestamps must be set explicitly in application code.

model User {
  id              String           @id @default(cuid()) @map("_id")
  authUserId      String           @unique
  email           String           @unique
  fullName        String?
  avatarUrl       String?
  passwordHash    String?
  createdAt       DateTime
  updatedAt       DateTime
  memberships     Membership[]
  ownedIncidents  Incident[]       @relation("IncidentOwner")
  incidentUpdates IncidentUpdate[]
  alertChannels   AlertChannel[]
  notifications   Notification[]
  createdApiKeys  ApiKey[]
}

model Workspace {
  id            String         @id @default(cuid()) @map("_id")
  name          String
  slug          String         @unique
  createdAt     DateTime
  updatedAt     DateTime
  memberships   Membership[]
  projects      Project[]
  incidents     Incident[]
  alertChannels AlertChannel[]
  alertRules    AlertRule[]
  statusPages   StatusPage[]
  notifications Notification[]
}

model Membership {
  id          String         @id @default(cuid()) @map("_id")
  role        String
  createdAt   DateTime
  updatedAt   DateTime
  workspaceId String
  userId      String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
}

model Project {
  id            String        @id @default(cuid()) @map("_id")
  name          String
  slug          String
  createdAt     DateTime
  updatedAt     DateTime
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id])
  environments  Environment[]
  services      Service[]
  incidents     Incident[]
  errorGroups   ErrorGroup[]
  alertRules    AlertRule[]
  statusPages   StatusPage[]
  apiKeys       ApiKey[]
}

model Environment {
  id           String       @id @default(cuid()) @map("_id")
  name         String
  key          String
  color        String?
  createdAt    DateTime
  updatedAt    DateTime
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id])
  monitors     Monitor[]
  incidents    Incident[]
  errorGroups  ErrorGroup[]
  alertRules   AlertRule[]
  deployments  Deployment[]
}

model Service {
  id               String             @id @default(cuid()) @map("_id")
  name             String
  slug             String
  description      String?
  createdAt        DateTime
  updatedAt        DateTime
  projectId        String
  project          Project            @relation(fields: [projectId], references: [id])
  monitors         Monitor[]
  incidents        Incident[]
  errorGroups      ErrorGroup[]
  statusPageLinks  StatusPageService[]
  alertRules       AlertRule[]
  deployments      Deployment[]
}

model ApiKey {
  id             String    @id @default(cuid()) @map("_id")
  name           String
  key            String    @unique
  prefix         String
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isRevoked      Boolean   @default(false)
  createdAt      DateTime
  updatedAt      DateTime
  projectId      String
  createdByUserId String?
  project        Project   @relation(fields: [projectId], references: [id])
  createdBy      User?     @relation(fields: [createdByUserId], references: [id])

  @@index([projectId])
}

model Monitor {
  id              String         @id @default(cuid()) @map("_id")
  name            String
  type            String         @default("HTTP")
  targetUrl       String
  method          String         @default("GET")
  expectedStatus  Int            @default(200)
  expectedKeyword String?
  intervalSeconds Int            @default(30)
  timeoutSeconds  Int            @default(10)
  isActive        Boolean        @default(true)
  createdAt       DateTime
  updatedAt       DateTime
  serviceId       String
  environmentId   String
  service         Service        @relation(fields: [serviceId], references: [id])
  environment     Environment    @relation(fields: [environmentId], references: [id])
  checkResults    CheckResult[]
}

model CheckResult {
  id           String       @id @default(cuid()) @map("_id")
  state        String
  statusCode   Int?
  latencyMs    Int?
  region       String?
  errorMessage String?
  metadata     Json?
  checkedAt    DateTime
  monitorId    String
  monitor      Monitor      @relation(fields: [monitorId], references: [id])
}

model Incident {
  id              String            @id @default(cuid()) @map("_id")
  title           String
  summary         String?
  severity        String
  status          String
  startedAt       DateTime
  resolvedAt      DateTime?
  createdAt       DateTime
  updatedAt       DateTime
  workspaceId     String
  projectId       String
  environmentId   String?
  serviceId       String?
  ownerUserId     String?
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  project         Project           @relation(fields: [projectId], references: [id])
  environment     Environment?      @relation(fields: [environmentId], references: [id])
  service         Service?          @relation(fields: [serviceId], references: [id])
  owner           User?             @relation("IncidentOwner", fields: [ownerUserId], references: [id])
  updates         IncidentUpdate[]
}

model IncidentUpdate {
  id          String             @id @default(cuid()) @map("_id")
  kind        String
  body        String
  createdAt   DateTime
  incidentId  String
  actorUserId String?
  incident    Incident           @relation(fields: [incidentId], references: [id])
  actor       User?              @relation(fields: [actorUserId], references: [id])
}

model ErrorGroup {
  id              String           @id @default(cuid()) @map("_id")
  fingerprint     String
  title           String
  status          String           @default("OPEN")
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  occurrenceCount Int              @default(1)
  createdAt       DateTime
  updatedAt       DateTime
  projectId       String
  environmentId   String
  serviceId       String?
  project         Project          @relation(fields: [projectId], references: [id])
  environment     Environment      @relation(fields: [environmentId], references: [id])
  service         Service?         @relation(fields: [serviceId], references: [id])
  events          ErrorEvent[]
}

model ErrorEvent {
  id           String     @id @default(cuid()) @map("_id")
  eventKey     String     @unique
  message      String
  stack        String?
  release      String?
  metadata     Json?
  occurredAt   DateTime
  createdAt    DateTime
  errorGroupId String
  errorGroup   ErrorGroup @relation(fields: [errorGroupId], references: [id])
}

model AlertChannel {
  id             String       @id @default(cuid()) @map("_id")
  name           String
  type           String
  destination    String
  secretRef      String?
  isEnabled      Boolean      @default(true)
  createdAt      DateTime
  updatedAt      DateTime
  workspaceId    String
  creatorUserId  String?
  workspace      Workspace    @relation(fields: [workspaceId], references: [id])
  creator        User?        @relation(fields: [creatorUserId], references: [id])
  alertRules     AlertRule[]
}

model AlertRule {
  id              String        @id @default(cuid()) @map("_id")
  name            String
  triggerType     String
  minimumSeverity String?
  isEnabled       Boolean       @default(true)
  createdAt       DateTime
  updatedAt       DateTime
  workspaceId     String
  projectId       String?
  environmentId   String?
  serviceId       String?
  alertChannelId  String
  workspace       Workspace     @relation(fields: [workspaceId], references: [id])
  project         Project?      @relation(fields: [projectId], references: [id])
  environment     Environment?  @relation(fields: [environmentId], references: [id])
  service         Service?      @relation(fields: [serviceId], references: [id])
  alertChannel    AlertChannel  @relation(fields: [alertChannelId], references: [id])
}

model StatusPage {
  id            String               @id @default(cuid()) @map("_id")
  name          String
  slug          String               @unique
  headline      String?
  visibility    String               @default("PUBLIC")
  createdAt     DateTime
  updatedAt     DateTime
  workspaceId   String
  projectId     String?
  workspace     Workspace            @relation(fields: [workspaceId], references: [id])
  project       Project?             @relation(fields: [projectId], references: [id])
  services      StatusPageService[]
}

model StatusPageService {
  id            String      @id @default(cuid()) @map("_id")
  displayName   String?
  sortOrder     Int         @default(0)
  statusPageId  String
  serviceId     String
  statusPage    StatusPage  @relation(fields: [statusPageId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])
}

model Deployment {
  id            String   @id @default(cuid()) @map("_id")
  version       String
  status        String   @default("SUCCEEDED")
  description   String?
  deployedBy    String?
  deployedAt    DateTime
  createdAt     DateTime
  updatedAt     DateTime
  environmentId String
  serviceId     String?
  environment   Environment @relation(fields: [environmentId], references: [id])
  service       Service?    @relation(fields: [serviceId], references: [id])

  @@index([environmentId, deployedAt])
}

model Notification {
  id         String      @id @default(cuid()) @map("_id")
  type       String
  title      String
  body       String?
  link       String?
  read       Boolean     @default(false)
  createdAt  DateTime
  updatedAt  DateTime
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  workspaceId String
  workspace  Workspace   @relation(fields: [workspaceId], references: [id])

  @@index([userId, read, createdAt])
}
