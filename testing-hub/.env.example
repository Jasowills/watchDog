# ── Sonar SDK configuration ──
# Get these values from your Sonar workspace → settings → API keys.

# Your project slug (shown as the first part of URL when viewing your project)
SONAR_PROJECT_KEY=my-awesome-api

# The environment key from your Sonar environment (e.g. "prod", "staging")
SONAR_ENVIRONMENT_KEY=env_production_key_here

# API key with ingest permissions — starts with "wdp_"
# Create one at: Sonar UI → Settings → API Keys
SONAR_API_KEY=wdp_xxxxxxxx_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# The Sonar server endpoint (leave as default for local dev)
SONAR_ENDPOINT=http://localhost:8080

# Which port the testing-hub itself runs on
PORT=3001
